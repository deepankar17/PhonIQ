    <string name="wire_phone_who_title">Who is this?</string>
    <string name="wire_phone_who_body">Fuse last PSTN/WA call, last SMS from the same sender, and your local notes — read-only until contacts + SMS are linked in Room.</string>
    <string name="wire_phone_merge_title">Merge / cleanup contacts</string>
    <string name="wire_phone_merge_body">Duplicate detection, format normalization, and merge preview — wizard UI from PROJECT.md lands here.</string>
    <string name="wire_phone_aftercall_title">After-call sheet</string>
    <string name="wire_phone_aftercall_body">Save contact, quick note, block, SMS template shortcuts — shown when a call ends once InCallService exists.</string>
    <string name="wire_phone_recording_title">Call recording</string>
    <string name="wire_phone_recording_body">Consent line, per-call toggle, encrypted local files, and a simple player/list — on-device only.</string>
    <string name="recording_library_disclosure">Recordings are encrypted and stored only on this device. Enable automatic recording under Settings → Personalization → Call recording, and obey local laws.</string>
    <string name="recording_library_empty">No saved recordings yet. Enable call recording in Settings → Personalization, then completed calls will list encrypted files here.</string>
    <string name="recording_playback_error">Could not play this recording.</string>
    <string name="wire_messages_bill_title">Bill hygiene</string>
    <string name="wire_messages_bill_body">Pin or archive promo senders, surface bill due rows, and keep OTP threads tidy — tied to the Money reminders slice.</string>
    <string name="wire_messages_otp_title">OTP center</string>
    <string name="wire_messages_otp_body">Expiry countdown + one-tap copy in list and thread; parses from SMS without network.</string>

    <string name="wire_phone_insights_title">Communication insights</string>
    <string name="wire_phone_insights_body">On-device stats: time on calls, top contacts, missed trends. No telemetry — all local aggregation once call log access exists.</string>

    <string name="sheet_mark_all_read_title">Mark all as read</string>
    <string name="sheet_mark_all_read_body">Marks every thread in this prototype list as read. With the default SMS app role, PhonIQ will sync read state to the provider and Room.</string>
    <string name="sheet_mark_all_read_confirm">Mark all read</string>
    <string name="sheet_inbox_cleaner_title">Inbox cleaner</string>
    <string name="sheet_inbox_cleaner_body">Dry-run preview for promo / OTP / bill hygiene. Nothing is deleted — this is a UI shell until SMS parsing and Room land.</string>
    <string name="sheet_inbox_bullet_promos">Pin or archive promo and marketing threads</string>
    <string name="sheet_inbox_bullet_otp">Tuck away OTP threads after you copy the code</string>
    <string name="sheet_inbox_bullet_bills">Surface bill due nudges next to Money reminders</string>
    <string name="sheet_inbox_run_preview">Run dry run</string>
    <string name="snackbar_all_threads_read">All threads marked read (prototype).</string>
    <string name="snackbar_inbox_dry_run">Dry run: 2 promo-like threads, 1 OTP thread, 1 bill row — actions are mocked.</string>
    <string name="wire_money_bill_title">Bill due</string>
    <string name="wire_money_bill_body">Credit card, gas, electricity, recharge — infer due dates from SMS and surface an upcoming list on Money / Messages.</string>
    <string name="wire_money_recurring_title">Recurring &amp; transfers</string>
    <string name="wire_money_recurring_body">Standing instructions, SIP debits, periodic IMPS/NEFT patterns as reminders — separate cards from bill-due.</string>
    <string name="wire_money_salary_title">Salary (FY)</string>
    <string name="wire_money_salary_body">Detect salary credits, exclude from discretionary spend, show yearly view — on-device heuristics + user confirm.</string>
    <string name="wire_money_invest_title">Investments (SMS IQ)</string>
    <string name="wire_money_invest_body">MF / broker / registrar-style SMS → IQ cards; ambiguous parses need user confirm (no live market data).</string>
    <string name="wire_money_export_title">Export</string>
    <string name="wire_money_export_body">Local CSV / PDF and optional manual upload to Drive only when you choose.</string>

