    <string name="wire_phone_delete_title">Delete all calls</string>
    <string name="wire_phone_delete_body">You will confirm once, then clear the on-device recents list. Default dialer + Room storage are not wired yet — this screen is a prototype placeholder.</string>
    <string name="wire_phone_insights_title">Communication insights</string>
    <string name="wire_phone_insights_body">On-device stats: time on calls, top contacts, missed trends. No telemetry — all local aggregation once call log access exists.</string>
    <string name="wire_messages_mark_read_title">Mark all read</string>
    <string name="wire_messages_mark_read_body">Batch mark threads read (SMS provider / default SMS role). Parser and Room inbox come next.</string>
    <string name="wire_messages_inbox_title">Inbox cleaner</string>
    <string name="wire_messages_inbox_body">Pin / archive promos, bill hygiene, OTP hygiene — flows from PROJECT.md will attach here.</string>
    <string name="wire_money_bill_title">Bill due</string>
    <string name="wire_money_bill_body">Credit card, gas, electricity, recharge — infer due dates from SMS and surface an upcoming list on Money / Messages.</string>
    <string name="wire_money_recurring_title">Recurring &amp; transfers</string>
    <string name="wire_money_recurring_body">Standing instructions, SIP debits, periodic IMPS/NEFT patterns as reminders — separate cards from bill-due.</string>
    <string name="wire_money_salary_title">Salary (FY)</string>
    <string name="wire_money_salary_body">Detect salary credits, exclude from discretionary spend, show yearly view — on-device heuristics + user confirm.</string>
    <string name="wire_money_invest_title">Investments (SMS IQ)</string>
    <string name="wire_money_invest_body">MF / broker / registrar-style SMS → IQ cards; ambiguous parses need user confirm (no live market data).</string>
    <string name="wire_money_export_title">Export</string>
    <string name="wire_money_export_body">Local CSV / PDF and optional manual upload to Drive only when you choose.</string>
